
# MongoDB connection string (replace with your actual MongoDB URI)
MONGO_URI=mongodb://localhost:27017/cpcoach

# JWT secret (generate a strong random value for production)
JWT_SECRET=your_super_secret_jwt_key_here

# Server port (default 5000)
PORT=5000

# LLM API keys (get from respective providers)
# Primary: Deepseek API key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Fallback: OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# Fallback: Google Gemini API key
GEMINI_API_KEY=your_google_gemini_api_key_here

# LLM provider preference (deepseek, openai, gemini)
LLM_PROVIDER=deepseek

# Optional: Custom Deepseek API URL (default is fine)
# DEEPSEEK_API_URL=https://api.deepseek.ai/v1/generate

# Production settings
NODE_ENV=production